APP_ENV=development
LOG_LEVEL=INFO
BOT_DATA_MODE=mock
MOCK_SCENARIO=healthy-system

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_INCIDENT_CHAT_ID=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_ANALYSIS_ENABLED=true
DATABASE_PATH=./data/agrivo-sre-bot.db

AGRIVO_FRONTEND_URL=http://localhost:8090
AGRIVO_BACKEND_URL=http://localhost:5001
AGRIVO_BACKEND_HEALTH_URL=http://localhost:5001/api/health
AGRIVO_BACKEND_LIVE_URL=http://localhost:5001/api/health/live
AGRIVO_BACKEND_READY_URL=http://localhost:5001/api/health/ready
AGRIVO_BACKEND_METRICS_URL=http://localhost:5001/api/metrics

# For local port-forwards use localhost. For cluster deployment use service DNS names.
PROMETHEUS_URL=http://localhost:9090
ALERTMANAGER_URL=http://localhost:9093
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=
GRAFANA_RENDER_ENABLED=false
GRAFANA_DASHBOARD_OVERVIEW_URL=
GRAFANA_DASHBOARD_BACKEND_URL=
GRAFANA_DASHBOARD_KUBERNETES_URL=
GRAFANA_DASHBOARD_INCIDENTS_URL=

KUBERNETES_IN_CLUSTER=false
KUBERNETES_CONTEXT=aks-agrivo-dev
KUBERNETES_NAMESPACE_DEV=agrivo-dev
KUBERNETES_NAMESPACE_PROD=agrivo-prod

ARGOCD_URL=http://localhost:8080
ARGOCD_TOKEN=
ARGOCD_VERIFY_TLS=false

GHCR_REGISTRY=ghcr.io
GHCR_FRONTEND_IMAGE=maryamjabrailova04/agrivo-frontend
GHCR_BACKEND_IMAGE=maryamjabrailova04/agrivo-backend
GITHUB_OWNER=MaryamJabrailova04
GITHUB_REPOSITORY=Agrivo
GITHUB_TOKEN=

DISPLAY_TIMEZONE=Asia/Baku
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3
